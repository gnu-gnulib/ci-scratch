libgmc.a: $(libgmc_a_OBJECTS) $(libgmc_a_DEPENDENCIES) $(EXTRA_libgmc_a_DEPENDENCIES) 
	$(AM_V_at)-rm -f libgmc.a
	$(AM_V_AR)$(libgmc_a_AR) libgmc.a $(libgmc_a_OBJECTS) $(libgmc_a_LIBADD)
	$(AM_V_at)$(libgmc_a_RANLIB) libgmc.a

mostlyclean-compile:
	-rm -f *.$(OBJEXT)
	-rm -f glthread/*.$(OBJEXT)
	-rm -f malloc/*.$(OBJEXT)
	-rm -f unicase/*.$(OBJEXT)
	-rm -f unictype/*.$(OBJEXT)
	-rm -f uniwidth/*.$(OBJEXT)

distclean-compile:
