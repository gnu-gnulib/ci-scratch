# This test expects compilation of test-verify-try.c to fail, and
# each time it fails, the makefile rule does not perform the usual
#  "mv -f $name.Tpo $name.po, so tell make clean to remove that file.
MOSTLYCLEANFILES = core *.stackdump byteswap.h byteswap.h-t endian.h \
	endian.h-t test-fflush.txt test-fpending.t t-fpurge.tmp \
	t-freading.tmp t-ftell3.tmp t-ftello3.tmp test-getdelim.txt \
	test-getline.txt test-glob.tglobfile test-glob.tgloblink1 \
	test-glob.tgloblink2 test-glob.tgloblink3 $(am__append_43) \
	test-posix_spawn-dup2-stdout.sh \
	test-posix_spawn-dup2-stdout.sh-t \
	test-posix_spawn-dup2-stdin.sh \
	test-posix_spawn-dup2-stdin.sh-t $(am__append_92) \
	.deps/test-verify-try.Tpo
